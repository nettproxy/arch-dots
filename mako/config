font=Iosevka Regular 11
width=360
height=140
outer-margin=14,14,0,0
margin=8
padding=12,14
border-size=2
border-radius=6

background-color=#0d0f0ff2
text-color=#d7fbe8
border-color=#8bd49c
progress-color=over #8bd49c

icons=1
max-icon-size=42
icon-border-radius=5
markup=1
actions=1
history=1
max-visible=5
max-history=20
sort=-time

anchor=top-right
layer=overlay
default-timeout=6000
ignore-timeout=0

format=<b>%s</b>\n%b

[urgency=low]
border-color=#52685b
text-color=#b8e6c9
default-timeout=3500

[urgency=normal]
border-color=#8bd49c

[urgency=critical]
border-color=#e67e80
progress-color=over #e67e80
default-timeout=0

[mode=do-not-disturb]
invisible=1
